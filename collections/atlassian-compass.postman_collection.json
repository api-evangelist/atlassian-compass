  "info": {
    "_postman_id": "cfec77c0-ef7f-4b54-bfab-15b32baaf1cf",
    "name": "Atlassian Compass REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Atlassian Compass is a developer experience platform with a software\ncomponent catalog, scorecards, metrics, and event ingestion. This\ndocument describes the public REST API v2 (`/compass/v1`) used to send\nmetric values and events. Most Compass operations (querying components,\nscorecards, dependencies, etc.) are exposed via the Compass GraphQL API\nat https://api.atlassian.com/graphql and not enumerated here.\n\n\nContact Support:\n Name: Atlassian Developer",
      "type": "text/plain"
    }
  }
